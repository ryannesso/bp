<launch>
    <arg name="model_path" default="$(find road_segmentation)/models/hybridnets_512x640.onnx"/>
    
    <node name="road_segmentation_node" pkg="road_segmentation" type="road_segmentation_node.py" output="screen">
        <param name="model_path" value="$(arg model_path)"/>
        <!-- Настройки IPM (если нужно подправить под вашу камеру) -->
        <param name="grid_resolution" value="0.05"/>
    </node>
</launch>
