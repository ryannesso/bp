<launch>
    <!-- 1. ЗАПУСК ВИДЕО (Публикует в топик /videofile/image_raw) -->
    <include file="$(find video_stream_opencv)/launch/camera.launch">
        <arg name="video_stream_provider" value="/home/yehor/work_disk/downloads/3.mp4" />
        <arg name="loop_videofile" value="true" />
        <!-- Называем камеру videofile, чтобы она не конфликтовала ни с чем -->
        <arg name="camera_name" value="videofile" /> 
        <arg name="visualize" value="true" />
    </include>

    <!-- ЗАКОММЕНТИРОВАНО: Старая C++ Нода
    <node name="path_detector" pkg="path_detector" type="path_detection" output="screen">
        <remap from="/camera/image_raw" to="/videofile/image_raw"/>
        
        <param name="frame_id" value="base_link"/>
        <param name="interactive_mask" value="false"/>
        <param name="standalone_mode" value="false"/>
        <param name="use_convex_hull" value="true" />
        <param name="v_offset" value="80" />
        <param name="use_grass_exclusion" value="true" />
        
        <param name="gh_low" value="25" />
        <param name="gs_low" value="40" />
        <param name="gv_low" value="40" />
        <param name="gh_high" value="65" />
        <param name="gs_high" value="255" />
        <param name="gv_high" value="255" />
        
        <param name="mask_lb_x" value="0" />   
        <param name="mask_rb_x" value="100" /> 
        <param name="mask_lt_x" value="0" />   
        <param name="mask_rt_x" value="100" /> 
        <param name="mask_t_y" value="36" />   
        <param name="mask_b_y" value="100" />  
    </node>
    -->

    <!-- НОВАЯ PYTHON НОДА -->
    <node name="path_detector_python" pkg="path_detector" type="path_detection.py" output="screen">
        <remap from="/camera/image_raw" to="/videofile/image_raw"/>
        
        <!-- Параметры для нового Python скрипта -->
        <param name="color_tolerance" value="25.0" />
        <param name="texture_thresh" value="25.0" />
        <param name="edge_thresh" value="40" />
        <param name="grid_resolution" value="0.05" />
    </node>
</launch>